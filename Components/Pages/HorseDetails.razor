@page "/horses/{slug}"
@using Microsoft.AspNetCore.Components
@using StallNysater.Models
@using StallNysater.Services
@inject HorseService HorseService
@inject NavigationManager NavigationManager

<PageTitle>Stall Nysäter's Hästar</PageTitle>

@if (horse is null)
{
    <h3>Hästen hittades inte.</h3>
}
else
{
    <div class="horse-details-page">
        <img src="@horse.ImageUrl" alt="@horse.Name" class="horse-details-image" />

        <h1>@horse.Name</h1>

        <p><strong>Född:</strong> @horse.BirthDate</p>
        <p><strong>Stam:</strong> @horse.Pedigree</p>
        <p><strong>Uppfödare:</strong> @horse.Breeder</p>
        <p><strong>Ägare/Tränare:</strong> @horse.OwnerTrainer</p>

        @if (!string.IsNullOrWhiteSpace(horse.Description))
        {
            <p>@horse.Description</p>
        }

        <a class="back-button" href="/horses">← Tillbaka</a>
    </div>
}
@code {
    [Parameter]
    public string slug { get; set; } = "";

    private Horse? horse;

    protected override void OnParametersSet()
    {
        horse = HorseService.GetBySlug(slug);
    }
  
}