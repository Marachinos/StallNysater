@page "/memorial/{categorySlug}/{horseSlug}"
@using Microsoft.AspNetCore.Components
@using StallNysater.Models
@using StallNysater.Services
@inject MemorialService MemorialService

<PageTitle>Hästar vi minns</PageTitle>

@if (horse is null)
{
    <div class="page-section">
        <h3>Hästen hittades inte.</h3>
        <a class="back-button" href="/memorial">← Tillbaka</a>
    </div>
}
else
{
    <div class="horse-details-page">
        <img src="@horse.ImageUrl" alt="@horse.Name" class="horse-details-image" />

        <h1>@horse.Name</h1>

        @if (!string.IsNullOrWhiteSpace(horse.BirthDate))
        {
            <p><strong>Född:</strong> @horse.BirthDate</p>
        }

        @if (!string.IsNullOrWhiteSpace(horse.Description))
        {
            <p class="multiline-text">@((MarkupString)horse.Description)</p>
        }

        @if (horse.Summary is not null)
        {
            <h2>Tävlingsresultat</h2>

            <div class="results-summary">
                <p>@horse.Summary.Starts</p>
                <p>@horse.Summary.Earnings</p>
                <p>@horse.Summary.Placings</p>
                <p>@horse.Summary.Records</p>
            </div>
        }
        @if (horse.Results.Any())
        {
            <div class="results-table-wrapper">
                <div class="results-table-card">
                    <table class="results-table">
                        <thead>
                            <tr>
                                <th>Datum</th>
                                <th>Bana</th>
                                <th>Placering</th>
                                <th>Distans</th>
                                <th>Tid</th>
                                <th>Kusk</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in horse.Results)
                            {
                                <tr>
                                    <td data-label="Datum">@result.Date</td>
                                    <td data-label="Bana">@result.Track</td>
                                    <td data-label="Placering">@result.Placement</td>
                                    <td data-label="Distans">@result.Distance</td>
                                    <td data-label="Tid">@result.Time</td>
                                    <td data-label="Kusk">@result.Driver</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        <a class="back-button" href="@($"/memorial/{categorySlug}")">← Tillbaka</a>
    </div>
}

@code {
    [Parameter]
    public string categorySlug { get; set; } = "";

    [Parameter]
    public string horseSlug { get; set; } = "";

    private MemorialHorse? horse;

    protected override void OnParametersSet()
    {
        horse = MemorialService.GetHorse(categorySlug, horseSlug);
    }
}